{
  "name": "@jhs-computer/database",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "db:bootstrap:server": "ts-node -r tsconfig-paths/register src/main.ts --bootstrap-server",
    "db:apply": "npm run db:apply:dev",
    "db:apply:dev": "ts-node -r tsconfig-paths/register src/main.ts --apply --target=dev",
    "db:apply:stage": "ts-node -r tsconfig-paths/register src/main.ts --apply --target=stage",
    "db:apply:prod": "ts-node -r tsconfig-paths/register src/main.ts --apply --target=prod",
    "db:reset": "npm run db:reset:dev",
    "db:reset:dev": "ts-node -r tsconfig-paths/register src/main.ts --reset --target=dev",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "mysql2": "^3.14.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@types/node": "^24.0.10",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3"
  }
}
